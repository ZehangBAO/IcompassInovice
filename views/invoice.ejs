<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice #<%= invoice.invoiceNumber %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f3f4f6; color: #111827; }

    .invoice-wrapper { max-width: 800px; margin: 40px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,.12); }

    .invoice-header { background: #2563eb; color: #fff; padding: 40px 50px 30px; display: flex; justify-content: space-between; align-items: flex-start; }
    .invoice-header .logo-text { font-size: 13px; opacity: .8; margin-bottom: 4px; }
    .invoice-header h1 { font-size: 36px; letter-spacing: 4px; font-weight: 800; }
    .invoice-meta { text-align: right; font-size: 13px; line-height: 1.7; }
    .invoice-meta .inv-number { font-size: 18px; font-weight: 700; }

    .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 30px 50px; background: #f9fafb; border-bottom: 1px solid #e5e7eb; }
    .party-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #6b7280; margin-bottom: 6px; }
    .party-name { font-size: 16px; font-weight: 600; color: #111827; }
    .party-detail { font-size: 13px; color: #374151; line-height: 1.6; margin-top: 4px; white-space: pre-line; }

    .items-section { padding: 30px 50px; }
    .items-section table { width: 100%; border-collapse: collapse; }
    .items-section thead tr { background: #2563eb; color: #fff; }
    .items-section th { padding: 10px 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; }
    .items-section th:first-child { border-radius: 4px 0 0 4px; }
    .items-section th:last-child { border-radius: 0 4px 4px 0; }
    .items-section td { padding: 12px 12px; font-size: 14px; border-bottom: 1px solid #f3f4f6; }
    .items-section tr:last-child td { border-bottom: none; }
    .items-section tr:nth-child(even) td { background: #f9fafb; }
    .text-right { text-align: right; }
    .text-center { text-align: center; }

    .totals-section { display: flex; justify-content: flex-end; padding: 0 50px 30px; }
    .totals-table { width: 280px; }
    .totals-table tr td { padding: 6px 0; font-size: 14px; color: #374151; }
    .totals-table tr td:last-child { text-align: right; font-variant-numeric: tabular-nums; }
    .totals-divider td { border-top: 2px solid #2563eb; padding-top: 10px !important; }
    .totals-grand td { font-size: 16px; font-weight: 700; color: #1e40af; }

    .notes-section { padding: 20px 50px 30px; border-top: 1px solid #e5e7eb; }
    .notes-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #6b7280; margin-bottom: 8px; }
    .notes-text { font-size: 13px; color: #374151; line-height: 1.6; white-space: pre-line; }

    .invoice-footer { background: #f9fafb; padding: 16px 50px; text-align: center; font-size: 12px; color: #9ca3af; border-top: 1px solid #e5e7eb; }

    .print-actions { text-align: center; padding: 20px; display: flex; gap: 12px; justify-content: center; }
    .btn { padding: 10px 24px; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-secondary { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }
    .btn-secondary:hover { background: #e5e7eb; }

    @media print {
      body { background: #fff; }
      .invoice-wrapper { box-shadow: none; margin: 0; border-radius: 0; }
      .print-actions { display: none; }
    }
  </style>
</head>
<body>

<% if (mode === 'preview') { %>
<div class="print-actions">
  <button class="btn btn-primary" onclick="window.print()">Print / Save as PDF</button>
  <button class="btn btn-secondary" onclick="window.close()">Close</button>
</div>
<% } %>

<div class="invoice-wrapper">
  <!-- Header -->
  <div class="invoice-header">
    <div>
      <div class="logo-text">IcompassInvoice</div>
      <h1>INVOICE</h1>
    </div>
    <div class="invoice-meta">
      <div class="inv-number">#<%= invoice.invoiceNumber %></div>
      <div>Date: <%= invoice.invoiceDate ? new Date(invoice.invoiceDate + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) : '' %></div>
      <% if (invoice.dueDate) { %>
      <div>Due: <%= new Date(invoice.dueDate + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></div>
      <% } %>
      <div>Currency: <%= invoice.currency %></div>
    </div>
  </div>

  <!-- Parties -->
  <div class="parties">
    <div>
      <div class="party-label">From</div>
      <div class="party-name"><%= invoice.sender.name || '—' %></div>
      <% if (invoice.sender.address) { %><div class="party-detail"><%= invoice.sender.address %></div><% } %>
      <% if (invoice.sender.email) { %><div class="party-detail"><%= invoice.sender.email %></div><% } %>
      <% if (invoice.sender.phone) { %><div class="party-detail"><%= invoice.sender.phone %></div><% } %>
    </div>
    <div>
      <div class="party-label">To</div>
      <div class="party-name"><%= invoice.recipient.name || '—' %></div>
      <% if (invoice.recipient.address) { %><div class="party-detail"><%= invoice.recipient.address %></div><% } %>
      <% if (invoice.recipient.email) { %><div class="party-detail"><%= invoice.recipient.email %></div><% } %>
      <% if (invoice.recipient.phone) { %><div class="party-detail"><%= invoice.recipient.phone %></div><% } %>
    </div>
  </div>

  <!-- Items -->
  <div class="items-section">
    <table>
      <thead>
        <tr>
          <th>Description</th>
          <th class="text-center">Qty</th>
          <th class="text-right">Unit Price</th>
          <th class="text-right">Total</th>
        </tr>
      </thead>
      <tbody>
        <% invoice.items.forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="text-center"><%= item.quantity %></td>
          <td class="text-right"><%= getCurrencySymbol(invoice.currency) %><%= item.unitPrice.toFixed(2) %></td>
          <td class="text-right"><%= getCurrencySymbol(invoice.currency) %><%= item.total.toFixed(2) %></td>
        </tr>
        <% }); %>
        <% if (invoice.items.length === 0) { %>
        <tr><td colspan="4" style="text-align:center; color:#9ca3af; padding:20px">No items</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Totals -->
  <div class="totals-section">
    <table class="totals-table">
      <tr>
        <td>Subtotal</td>
        <td><%= getCurrencySymbol(invoice.currency) %><%= invoice.subtotal.toFixed(2) %></td>
      </tr>
      <% if (invoice.taxRate > 0) { %>
      <tr>
        <td>Tax (<%= invoice.taxRate %>%)</td>
        <td><%= getCurrencySymbol(invoice.currency) %><%= invoice.taxAmount.toFixed(2) %></td>
      </tr>
      <% } %>
      <% if (invoice.discount > 0) { %>
      <tr>
        <td>Discount</td>
        <td>-<%= getCurrencySymbol(invoice.currency) %><%= invoice.discount.toFixed(2) %></td>
      </tr>
      <% } %>
      <tr class="totals-divider totals-grand">
        <td>Total Due</td>
        <td><%= getCurrencySymbol(invoice.currency) %><%= invoice.total.toFixed(2) %></td>
      </tr>
    </table>
  </div>

  <!-- Notes -->
  <% if (invoice.notes) { %>
  <div class="notes-section">
    <div class="notes-label">Notes</div>
    <div class="notes-text"><%= invoice.notes %></div>
  </div>
  <% } %>

  <div class="invoice-footer">
    Thank you for your business &mdash; Generated by IcompassInvoice
  </div>
</div>

<%
function getCurrencySymbol(currency) {
  const symbols = { USD: '$', EUR: '€', GBP: '£', CNY: '¥', JPY: '¥', AUD: 'A$', CAD: 'C$' };
  return symbols[currency] || (currency + ' ');
}
%>

</body>
</html>
