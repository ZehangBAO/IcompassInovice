<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IcompassInvoice – Create Invoice</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <rect width="28" height="28" rx="6" fill="#2563eb"/>
          <path d="M7 8h14M7 14h10M7 20h12" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span>IcompassInvoice</span>
      </div>
    </div>
  </header>

  <main class="container main-content">
    <h1 class="page-title">Create Invoice</h1>

    <form id="invoiceForm" method="POST">
      <!-- Invoice Details -->
      <section class="card">
        <h2 class="card-title">Invoice Details</h2>
        <div class="grid-3">
          <div class="form-group">
            <label for="invoiceNumber">Invoice Number</label>
            <input type="text" id="invoiceNumber" name="invoiceNumber" placeholder="INV-001" value="INV-001" />
          </div>
          <div class="form-group">
            <label for="invoiceDate">Invoice Date</label>
            <input type="date" id="invoiceDate" name="invoiceDate" />
          </div>
          <div class="form-group">
            <label for="dueDate">Due Date</label>
            <input type="date" id="dueDate" name="dueDate" />
          </div>
        </div>
        <div class="grid-3">
          <div class="form-group">
            <label for="currency">Currency</label>
            <select id="currency" name="currency">
              <option value="USD">USD – US Dollar</option>
              <option value="EUR">EUR – Euro</option>
              <option value="GBP">GBP – British Pound</option>
              <option value="CNY">CNY – Chinese Yuan</option>
              <option value="JPY">JPY – Japanese Yen</option>
              <option value="AUD">AUD – Australian Dollar</option>
              <option value="CAD">CAD – Canadian Dollar</option>
            </select>
          </div>
        </div>
      </section>

      <!-- From / To -->
      <div class="grid-2">
        <section class="card">
          <h2 class="card-title">From (Sender)</h2>
          <div class="form-group">
            <label for="senderName">Company / Name</label>
            <input type="text" id="senderName" name="senderName" placeholder="Your Company Name" />
          </div>
          <div class="form-group">
            <label for="senderAddress">Address</label>
            <textarea id="senderAddress" name="senderAddress" rows="3" placeholder="123 Main St, City, Country"></textarea>
          </div>
          <div class="form-group">
            <label for="senderEmail">Email</label>
            <input type="email" id="senderEmail" name="senderEmail" placeholder="you@company.com" />
          </div>
          <div class="form-group">
            <label for="senderPhone">Phone</label>
            <input type="tel" id="senderPhone" name="senderPhone" placeholder="+1 (555) 000-0000" />
          </div>
        </section>

        <section class="card">
          <h2 class="card-title">To (Recipient)</h2>
          <div class="form-group">
            <label for="recipientName">Company / Name</label>
            <input type="text" id="recipientName" name="recipientName" placeholder="Client Company Name" />
          </div>
          <div class="form-group">
            <label for="recipientAddress">Address</label>
            <textarea id="recipientAddress" name="recipientAddress" rows="3" placeholder="456 Client Ave, City, Country"></textarea>
          </div>
          <div class="form-group">
            <label for="recipientEmail">Email</label>
            <input type="email" id="recipientEmail" name="recipientEmail" placeholder="client@example.com" />
          </div>
          <div class="form-group">
            <label for="recipientPhone">Phone</label>
            <input type="tel" id="recipientPhone" name="recipientPhone" placeholder="+1 (555) 000-0001" />
          </div>
        </section>
      </div>

      <!-- Line Items -->
      <section class="card">
        <h2 class="card-title">Line Items</h2>
        <div class="items-table-wrapper">
          <table class="items-table" id="itemsTable">
            <thead>
              <tr>
                <th class="col-desc">Description</th>
                <th class="col-qty">Qty</th>
                <th class="col-price">Unit Price</th>
                <th class="col-total">Total</th>
                <th class="col-action"></th>
              </tr>
            </thead>
            <tbody id="itemsBody">
              <tr class="item-row">
                <td><input type="text" name="itemDescription" placeholder="Service or product description" /></td>
                <td><input type="number" name="itemQuantity" placeholder="1" min="0" step="any" class="qty-input" /></td>
                <td><input type="number" name="itemUnitPrice" placeholder="0.00" min="0" step="0.01" class="price-input" /></td>
                <td class="row-total">$0.00</td>
                <td><button type="button" class="btn-icon remove-row" title="Remove row" aria-label="Remove row">✕</button></td>
              </tr>
            </tbody>
          </table>
        </div>
        <button type="button" id="addRow" class="btn btn-outline">+ Add Item</button>
      </section>

      <!-- Totals & Notes -->
      <div class="grid-2">
        <section class="card">
          <h2 class="card-title">Notes</h2>
          <div class="form-group">
            <textarea id="notes" name="notes" rows="5" placeholder="Payment terms, bank details, or any additional information…"></textarea>
          </div>
        </section>

        <section class="card totals-card">
          <h2 class="card-title">Summary</h2>
          <div class="summary-row">
            <span>Subtotal</span>
            <span id="subtotalDisplay">$0.00</span>
          </div>
          <div class="summary-row">
            <label for="taxRate">Tax Rate (%)</label>
            <input type="number" id="taxRate" name="taxRate" placeholder="0" min="0" max="100" step="0.1" class="inline-input" value="0" />
          </div>
          <div class="summary-row" id="taxRow" style="display:none">
            <span id="taxLabel">Tax (0%)</span>
            <span id="taxDisplay">$0.00</span>
          </div>
          <div class="summary-row">
            <label for="discount">Discount ($)</label>
            <input type="number" id="discount" name="discount" placeholder="0.00" min="0" step="0.01" class="inline-input" value="0" />
          </div>
          <div class="summary-row" id="discountRow" style="display:none">
            <span>Discount</span>
            <span id="discountDisplay">-$0.00</span>
          </div>
          <div class="summary-divider"></div>
          <div class="summary-row total-row">
            <strong>Total Due</strong>
            <strong id="totalDisplay">$0.00</strong>
          </div>
        </section>
      </div>

      <!-- Actions -->
      <div class="actions">
        <button type="submit" formaction="/preview" formtarget="_blank" class="btn btn-secondary">
          Preview Invoice
        </button>
        <button type="submit" formaction="/pdf" class="btn btn-primary">
          Download PDF
        </button>
      </div>
    </form>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>IcompassInvoice &copy; 2026</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
